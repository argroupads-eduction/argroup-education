# Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=AR Group of Education

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTAG_ID=

# CMS (Payload — marketing site reads pages/globals from here)
NEXT_PUBLIC_CMS_URL=http://localhost:8000
# Optional: server-only URL for API routes / RSC (use 127.0.0.1 on Windows if localhost gives 503)
# PAYLOAD_CMS_URL=http://127.0.0.1:8000

# Slug of the Payload `pages` document for `/` and `/home` (default: home). Use e.g. mbbs-india if that is your main CMS page until you create `home`.
# NEXT_PUBLIC_CMS_HOME_SLUG=home

# Draft preview from Payload live preview (create a Users API key in Payload admin)
# PAYLOAD_PREVIEW_API_KEY=

# Must match Payload PREVIEW_SECRET — used by GET /api/draft
# PREVIEW_SECRET=

# Must match Payload FRONTEND_REVALIDATE_SECRET — used by POST /api/revalidate
# REVALIDATE_SECRET=

# Hero MBBS India form (Payload → Forms). Prefer numeric id from the form URL in admin.
# PAYLOAD_MBBS_INDIA_FORM_ID=3
# Or match by title (case-insensitive fallback if exact match fails):
# PAYLOAD_MBBS_INDIA_FORM_TITLE=MBBS INDIA
# Hero MBBS Abroad form (Payload → Forms). Title default MBBS ABROAD.
# PAYLOAD_MBBS_ABROAD_FORM_ID=
# PAYLOAD_MBBS_ABROAD_FORM_TITLE=MBBS ABROAD
# Optional: dedicated Payload form id for the site-load lead popup (falls back to MBBS Abroad form)
# NEXT_PUBLIC_LEAD_CAPTURE_FORM_ID=
# If forms are restricted, use a Users API key:
# PAYLOAD_CMS_API_KEY=

# External Services
NEXT_PUBLIC_CLOUDINARY_NAME=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true

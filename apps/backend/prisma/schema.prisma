// Prisma Schema for AR Group of Education Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL (Neon "Connect" with connection pooling ON) — use in app runtime
  url       = env("DATABASE_URL")
  // Direct URL (Neon "Connect" with pooling OFF) — required for Prisma migrations
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// Blog Models (WordPress posts)
model BlogPost {
  id               String    @id @default(cuid())
  wpId             Int?      @unique
  title            String
  slug             String    @unique
  content          String    @db.Text
  excerpt          String    @db.Text
  featuredImage    String?
  category         String    @default("Blog")
  tags             String[]
  metaTitle        String?
  metaDescription  String?
  canonicalUrl     String?
  keywords         String[]
  author           String    @default("AR Group")
  published        Boolean   @default(false)
  publishedAt      DateTime?
  views            Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
}

// WordPress pages (colleges, countries, static pages)
model SitePage {
  id               String    @id @default(cuid())
  wpId             Int       @unique
  title            String
  slug             String    @unique
  content          String    @db.Text
  excerpt          String?   @db.Text
  featuredImage    String?
  metaTitle        String?
  metaDescription  String?
  canonicalUrl     String?
  keywords         String[]
  published        Boolean   @default(true)
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

// Country Models
model Country {
  id               String   @id @default(cuid())
  name             String   @unique
  slug             String   @unique
  description      String   @db.Text
  image            String?
  flag             String?
  medicalSchools   Int      @default(0)
  fees             String?
  duration         String?
  neetScore        String?
  benefits         String[]
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  universities     University[]
  
  @@index([featured])
}

// University Models
model University {
  id               String   @id @default(cuid())
  name             String   @unique
  slug             String   @unique
  countryId        String
  country          Country  @relation(fields: [countryId], references: [id])
  description      String   @db.Text
  image            String?
  rating           Float    @default(0)
  fees             String?
  duration         String?
  neetScore        String?
  admission        String?
  affiliations     String[]
  placement        Int      @default(0)
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([featured])
  @@index([countryId])
}

// Leads Models
model Lead {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String
  course           String
  neetScore        String?
  countryPreference String
  status           String   @default("new")
  source           String   @default("website")
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

// Newsletter Subscription
model Subscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  subscribedAt     DateTime @default(now())
  unsubscribedAt   DateTime?
  active           Boolean  @default(true)
  
  @@index([active])
}

// Contact Form Submissions
model ContactSubmission {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  subject          String
  message          String   @db.Text
  read             Boolean  @default(false)
  createdAt        DateTime @default(now())
  
  @@index([read])
  @@index([createdAt])
}

// Testimonials
model Testimonial {
  id               String   @id @default(cuid())
  name             String
  image            String?
  review           String   @db.Text
  university       String
  country          String
  rating           Int      @default(5)
  course           String
  featured         Boolean  @default(false)
  approved         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([featured])
  @@index([approved])
}

// Gallery
model GalleryImage {
  id               String   @id @default(cuid())
  title            String
  image            String
  category         String
  description      String?  @db.Text
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([category])
  @@index([featured])
}

// Admin Users
model AdminUser {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  role             String   @default("admin")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastLogin        DateTime?
  
  @@index([active])
}

# Backend Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (Neon: pooled URL + direct URL from Console → Connect)
# Pooled URL (hostname contains -pooler.) — app runtime; Prisma adds pgbouncer=true automatically
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct URL (no -pooler) — migrations only (prisma migrate)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@argroup.edu

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# External Services
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Integration
WHATSAPP_API_URL=
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

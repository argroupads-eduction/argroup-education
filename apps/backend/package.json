{
  "name": "ar-education-backend",
  "version": "1.0.0",
  "description": "Backend API for AR Group of Education",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev -r dotenv/config --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "npx eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:ping": "node scripts/test-db-connection.mjs",
    "seed": "ts-node src/seed.ts",
    "wp:import": "node --env-file=.env scripts/import-wp.mjs",
    "wp:import:pages": "node --env-file=.env scripts/import-wp.mjs -- --pages-only"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "@prisma/client": "^5.6.0",
    "zod": "^3.22.4",
    "axios": "^1.6.2",
    "nodemailer": "^6.9.7",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prisma": "^5.6.0"
  }
}
